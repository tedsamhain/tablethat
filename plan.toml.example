# plan configuration — all values shown are defaults
# Place as plan.toml in project root, or ~/.config/plan/config.toml

# Default view when running `plan` with no subcommand: "list" or "kanban"
# default_view = "list"

# Editor for `plan open` (falls back to $EDITOR)
# editor = "vim"

# Sort keys for list view (repeatable)
# default_sort = ["priority", "slug"]

# Column order for kanban view
# kanban_order = ["idea", "backlog", "open", "in-progress", "blocked", "done"]

# Theme directory (default: ./themes/)
# themes_dir = "themes"

# Colors: named (red, green, blue, cyan, magenta, yellow, gray, darkgray, white),
# light variants (lightred, lightblue, ...), ANSI256 index ("42"), or hex ("#FF8800")
#
# Themes are defined in themes/*.toml files, not here.
# Use `themes_dir` above to change where they're loaded from.

# [colors.status]
# in_progress = "magenta"
# open = "yellow"
# blocked = "red"
# backlog = "blue"
# idea = "cyan"
# done = "green"

# [colors.priority]
# high = "red"
# medium = "yellow"
# low = "darkgray"
