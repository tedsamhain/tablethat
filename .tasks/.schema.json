{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Schema for .tasks/*.md YAML frontmatter. Filename (without .md) is the unique task key.",
  "type": "object",
  "required": ["status", "type", "priority"],
  "properties": {
    "status": {
      "enum": ["idea", "backlog", "open", "in-progress", "blocked", "done"]
    },
    "type": {
      "enum": ["bug", "feature", "chore", "decision", "perf"]
    },
    "priority": {
      "enum": ["high", "medium", "low"]
    },
    "area": {
      "description": "Optional grouping label for filtering (e.g. backend, frontend, devops, testing)",
      "type": "string"
    }
  },
  "additionalProperties": false
}
